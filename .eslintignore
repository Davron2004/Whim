# Lint scope mirrors tsconfig.json's `exclude` — same files, same reasons — plus the
# browser-context runtime JS that is inlined into the WebView srcdoc as strings (not RN/Node
# source) and deliberately reaches for eval / forbidden globals to probe or build the sandbox.
# Keep this in sync with tsconfig.json when its excludes change.

node_modules/
**/Pods/

# Auto-generated by `npm run build` — never hand-edited, never linted.
build/generated/
src/runtime/generated/

# Adversarial pen-test fixtures + the invariants suite: esbuild/Node-only inputs that
# DELIBERATELY use document/window/off-allowlist modules to attack the sandbox.
fixtures/adversarial/
invariants/

# Node-only acceptance runners (also tsconfig-excluded): use process / node:fs / dynamic import.
src/host/version-store/test/
src/host/storage-engine/test/
src/host/bridge/test/

# Browser-context runtime: inlined into the WebView as strings; uses eval/Function and reads
# forbidden globals (localStorage, Worker, …) by design to verify containment.
src/runtime/web/
build/react-inject.js
